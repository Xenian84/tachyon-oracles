# API Service Configuration

# Server
API_PORT=7171
API_HOST=0.0.0.0

# Security
API_KEY=your-generated-api-key-here
API_MODE=readonly
# API_MODE options:
#   readonly - Only status/monitoring (safest)
#   monitoring - Status + logs (recommended)
#   full - Full control including service management (use with caution)

# IP Whitelist (comma-separated, leave empty to allow all)
ALLOWED_IPS=

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=30

# Oracle Configuration
ORACLE_PROJECT_PATH=/root/tachyon-oracles
RPC_URL=https://rpc.mainnet.x1.xyz
PROGRAM_ID=TACH9r2uZzoFM6daofesADjeDn9NqB1pKFWP5mfByb1

# Logs
MAX_LOG_LINES=50
LOG_LEVEL=info

# HTTPS (optional)
ENABLE_HTTPS=false
SSL_KEY_PATH=
SSL_CERT_PATH=
