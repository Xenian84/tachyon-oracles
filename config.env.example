# Tachyon Oracles Configuration
# Copy this file to .env and customize for your setup

# ============================================================================
# PROGRAM CONFIGURATION
# ============================================================================

# Oracle program ID (deployed on X1)
PROGRAM_ID=TACH9r2uZzoFM6daofesADjeDn9NqB1pKFWP5mfByb1

# ============================================================================
# NETWORK CONFIGURATION
# ============================================================================

# X1 RPC endpoint
SOLANA_RPC_URL=https://rpc.mainnet.x1.xyz

# Alternative RPC endpoints (uncomment to use)
# SOLANA_RPC_URL=https://rpc2.mainnet.x1.xyz3
# SOLANA_RPC_URL=http://localhost:8899  # For local testing

# ============================================================================
# KEYPAIR PATHS
# ============================================================================

# Relayer keypair (pays for transactions)
# Default: ~/.config/solana/deployer.json
# RELAYER_KEYPAIR=/path/to/your/relayer-keypair.json

# Signer keypair (signs price updates)
# Default: ./keys/validator1-signer.json
# SIGNER_KEYPAIR=/path/to/your/signer-keypair.json

# Authority keypair (admin operations)
# Default: ~/.config/solana/deployer.json
# AUTHORITY_KEYPAIR=/path/to/your/authority-keypair.json

# ============================================================================
# RELAYER CONFIGURATION
# ============================================================================

# Port for relayer HTTP server
RELAYER_PORT=3000

# Maximum cached messages per asset
RELAYER_MAX_CACHE=100

# Submission interval (milliseconds)
RELAYER_SUBMIT_INTERVAL=30000

# ============================================================================
# SIGNER CONFIGURATION
# ============================================================================

# Price update interval (milliseconds)
SIGNER_INTERVAL=30000

# Relayer URL to submit signed messages
RELAYER_URL=http://localhost:3000

# ============================================================================
# PATHS (Auto-detected if not set)
# ============================================================================

# Solana CLI tools directory
# Auto-detected from: /root/tachyon/target/release, ~/.local/share/solana, or PATH
# SOLANA_PATH=/root/tachyon/target/release

# Solana config directory
# Auto-detected from: ~/.config/solana or /root/.config/solana
# SOLANA_CONFIG_DIR=/root/.config/solana

# Keys directory
# Default: ./keys
# KEYS_DIR=/path/to/your/keys

# Logs directory
# Default: ./logs
# LOGS_DIR=/path/to/your/logs

# ============================================================================
# MONITORING & ALERTS
# ============================================================================

# Enable monitoring (true/false)
MONITORING_ENABLED=true

# Alert threshold for low balance (SOL)
ALERT_LOW_BALANCE=1.0

# ============================================================================
# DATA SOURCES
# ============================================================================

# Price data sources (comma-separated)
PRICE_SOURCES=binance,coinbase,kraken

# ============================================================================
# ADVANCED SETTINGS
# ============================================================================

# Log level (debug, info, warn, error)
LOG_LEVEL=info

# Enable debug mode (true/false)
DEBUG=false

# Transaction confirmation commitment level
COMMITMENT_LEVEL=confirmed

# Maximum retries for failed transactions
MAX_RETRIES=3

# ============================================================================
# NOTES
# ============================================================================

# 1. Copy this file to .env: cp config.env.example .env
# 2. Never commit .env to version control (it's in .gitignore)
# 3. Most settings have sensible defaults and don't need to be changed
# 4. Paths are auto-detected if not specified
# 5. For production, ensure you have backups of all keypairs


