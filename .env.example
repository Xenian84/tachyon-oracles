# Tachyon Oracles Environment Configuration

# Cluster: local | x1
CLUSTER=local

# X1 Mainnet RPC
X1_RPC=https://rpc.mainnet.x1.xyz

# Program ID (set after deployment)
PROGRAM_ID=

# Relayer keypair path
RELAYER_KEYPAIR=./keys/relayer.json

# Signer keypair path (for validators)
SIGNER_KEYPAIR=./keys/signer.json

# Admin keypair path (for initialization)
ADMIN_KEYPAIR=./keys/admin.json

# Relayer service configuration
RELAYER_PORT=3000
RELAYER_HOST=0.0.0.0

# Signer daemon configuration
SIGNER_INTERVAL_MS=5000
RELAYER_URLS=http://localhost:7777

# Fee configuration (lamports)
UPDATE_FEE_LAMPORTS=0
RELAYER_CUT_BPS=1000

# Oracle configuration
MIN_PUBLISHERS=3
MAX_AGE_SEC=60
